#!/usr/bin/env sh
set -eu

BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
MAVEN_VERSION="3.9.9"
MAVEN_DIR="$WRAPPER_DIR/apache-maven-$MAVEN_VERSION"
MAVEN_CMD="$MAVEN_DIR/bin/mvn"
MAVEN_ZIP="$WRAPPER_DIR/apache-maven-$MAVEN_VERSION-bin.zip"
DISTRIBUTION_URL="https://archive.apache.org/dist/maven/maven-3/$MAVEN_VERSION/binaries/apache-maven-$MAVEN_VERSION-bin.zip"

if [ ! -f "$WRAPPER_DIR/maven-wrapper.properties" ]; then
  echo "No existe $WRAPPER_DIR/maven-wrapper.properties." >&2
  exit 1
fi

if [ ! -x "$MAVEN_CMD" ]; then
  echo "Descargando Apache Maven $MAVEN_VERSION para este proyecto..."
  mkdir -p "$WRAPPER_DIR"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$DISTRIBUTION_URL" -o "$MAVEN_ZIP"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$DISTRIBUTION_URL" -O "$MAVEN_ZIP"
  else
    echo "Se requiere curl o wget para descargar Maven." >&2
    exit 1
  fi
  if command -v unzip >/dev/null 2>&1; then
    unzip -q -o "$MAVEN_ZIP" -d "$WRAPPER_DIR"
  else
    echo "Se requiere unzip para descomprimir Maven." >&2
    exit 1
  fi
fi

exec "$MAVEN_CMD" "$@"
